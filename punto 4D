#include <iostream>
using namespace std;
int main() {

    int n, cont = 0;
    cout << "Cuantos numeros vas a poner?: ";
    cin >> n;

    int arr[100];

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    for(int i = 0; i < n; i++) {
        if(arr[i] % 2 == 0) {
            cont++;
        }
    }

    cout << "Hay " << cont << " numeros pares";
    return 0;
}
