#include <iostream>
using namespace std;
int main() {

    int n;
    cout << "Cuantos numeros enteros queres poner brrro?: ";
    cin >> n;

    int arr[100];

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int mayor = arr[0];

    for(int i = 1; i < n; i++) {
        if(arr[i] > mayor) {
            mayor = arr[i];
        }
    }

    cout << "El numero mas grande es " << mayor;
    return 0;
}
