#include <iostream>
using namespace std;
int main() {

    int num;
    int suma = 0;

    cout << "Poné varios numeros positivos y termina con un numero negativo:  ";
    cin >> num;

    while(num >= 0) {

        suma = suma + num;
        cin >> num;
    }
    cout << "La suma total es " << suma;

    return 0;
}
