#include <iostream>
using namespace std;
int main() {

    int num;
    int suma = 0;
    cout << "Poné un numero: ";
    cin >> num;

    for (int i = 1; i <= num; i++) {
        if (i % 2 != 0) {
            suma=suma + i;     
        }
    }
    cout << "La suma de los impares es "<< suma;

    return 0;
} 
