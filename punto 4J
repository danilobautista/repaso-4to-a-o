#include <iostream>
#include <cstdlib>
using namespace std;
int main() {

    string palabras[5] = {"Momonga", "Chiikawa", "Usagi", "Hachiware", "Rakko"};
    string palabra = palabras[rand()%5];
    string progreso = "";

    for(int i = 0; i < palabra.length(); i++) {
        progreso = progreso + "_";
    }

    char letra;

    while(progreso != palabra) {

        cout << progreso << endl;
        cout << "Letra: ";
        cin >> letra;

        for(int i = 0; i < palabra.length(); i++) {
            if(palabra[i] == letra) {
                progreso[i] = letra;
            }
        }
    }

    cout << "Ganaste bro, la palabra era " << palabra;

    return 0;
}
