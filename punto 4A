#include <iostream>
using namespace std;
int main() {

    int n, suma = 0;
    cout << "Cuantos numeros enteros vas a poner bordi?: ";
    cin >> n;

    int arr[100];

    for(int i = 0; i < n; i++) {
        cout << "Numero " << i+1 << ": ";
        cin >> arr[i];
    }

    for(int i = 0; i < n; i++) {
        suma = suma + arr[i];
    }
    cout << "La suma ess " << suma;

    return 0;
}
