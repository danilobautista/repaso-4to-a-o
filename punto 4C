#include <iostream>
using namespace std;
int main() {

    int n;
    cout << "Cuantos numeros vas a poner pe?: ";
    cin >> n;

    int arr[100];

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int menor = arr[0];

    for(int i = 1; i < n; i++) {
        if(arr[i] < menor) {
            menor = arr[i];
        }
    }

    cout << "El numero mas chico es " << menor;
    return 0;
}
