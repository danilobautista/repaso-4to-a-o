#include <iostream>
using namespace std;

int main() {

    int num1, num2;

    cout << "Poné el primer numero: ";
    cin >> num1;

    cout << "Poné el segundo numero: ";
    cin >> num2;

    if (num1 > num2) {
        cout << "El numero mas grande es " << num1;
    }
    else if (num2 > num1) {
        cout << "El numero mas grande es " << num2;
    }
    else {
        cout << "Los dos numeros son iguales XD";
    }
    return 0;
}
